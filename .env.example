# Required for persistent deployments. Provision Postgres through the Vercel
# Marketplace using Neon or Prisma Postgres, then Vercel injects DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Optional in V1. Deterministic policy and financial logic never depends on an LLM.
OPENAI_API_KEY=""
OPENAI_REASONING_MODEL="gpt-5-mini"

# Demo tenant. Replace with authenticated organization resolution after V1.
CANTINA_DEMO_USER_EMAIL="founder@cantina.local"
CANTINA_DEMO_ORG_SLUG="cantina-labs"
